# ── .NET ─────────────────────────────────────────────────────────────────────
bin/
obj/
*.user
*.suo
.vs/

# Local developer secrets — never commit DB credentials
backend/UPath.Api/appsettings.Development.json
backend/UPath.Api/appsettings.*.Local.json

# .NET user secrets store (dotnet user-secrets)
backend/UPath.Api/*.pfx

# ── Node.js / Frontend ────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
backend/_legacy/node_modules/

# Vite / build output
dist/
frontend/dist/
frontend/.vite/

# ── Environment files ─────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
# Keep .env.example files — they are safe templates with no real values
!.env.example
!frontend/.env.example

# ── Test / Coverage ───────────────────────────────────────────────────────────
coverage/
frontend/coverage/
TestResults/

# ── IDEs ─────────────────────────────────────────────────────────────────────
# JetBrains Rider / IntelliJ
.idea/
*.iml

# VS Code (keep shared settings, ignore personal overrides)
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json

# ── OS ───────────────────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble

# Windows
Thumbs.db
Desktop.ini

# ── Docker / deployment secrets ──────────────────────────────────────────────
# Let's Encrypt certs are managed by certbot on the server — ignore contents, keep dirs
nginx/certbot/conf/*
nginx/certbot/www/*
!nginx/certbot/conf/.gitkeep
!nginx/certbot/www/.gitkeep

# ── Misc ─────────────────────────────────────────────────────────────────────
*.log
*.tmp
